<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/superman_120"
        android:label="@string/app_name"
        android:roundIcon="@drawable/superman_120"
        android:supportsRtl="true"
        android:theme="@style/Theme.Supermand">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ManageExercisesActivity"
            android:label="Øvelser"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".WorkoutSessionActivity"
            android:label="Træningspas"
            android:windowSoftInputMode="adjustPan"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".StatisticsActivity"
            android:label="Statistik"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".CalendarActivity"
            android:label="Kalender"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ExerciseStatsActivity"
            android:label="Øvelsesstatistik"
            android:parentActivityName=".ManageExercisesActivity" />

    </application>

</manifest>
